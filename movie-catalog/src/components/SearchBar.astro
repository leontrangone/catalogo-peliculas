<section class="search-shell">
  <div class="search-row">
    <input type="text" id="searchInput" placeholder="Buscar película..." />
    <button id="searchBtn" type="button">Buscar</button>
  </div>
</section>

<script>
  const input = document.getElementById("searchInput");
  const searchBtn = document.getElementById("searchBtn");
  const container = document.getElementById("movies");
  const SEARCH_QUERY_KEY = "search:lastQuery";
  const SEARCH_RESULTS_KEY = "search:lastResults";
  let currentRequest = 0;
  let searchDebounce;

  function runAnimation(element, className = "run-animation") {
    element.classList.remove(className);
    void element.offsetWidth;
    element.classList.add(className);
  }

  function notifyFavoritesChanged() {
    window.dispatchEvent(new Event("favorites:changed"));
  }

  function renderMessage(text) {
    container.innerHTML = `<p class="message">${text}</p>`;
    runAnimation(container, "grow-once");
  }

  function renderSkeletons() {
    container.innerHTML = "";
    for (let i = 0; i < 8; i++) {
      const skel = document.createElement("div");
      skel.classList.add("skeleton");
      container.appendChild(skel);
    }
    runAnimation(container, "grow-once");
  }

  function saveSearchState(query, movies) {
    localStorage.setItem(SEARCH_QUERY_KEY, query);
    localStorage.setItem(SEARCH_RESULTS_KEY, JSON.stringify(movies));
  }

  function getFavorites() {
    return JSON.parse(localStorage.getItem("favs") || "[]");
  }

  function renderMovies(movies) {
    container.innerHTML = "";

    movies.forEach((movie, index) => {
      const div = document.createElement("div");
      div.classList.add("card");
      div.style.animationDelay = `${index * 45}ms`;
      div.innerHTML = `
        <img src="${movie.Poster}" alt="${movie.Title}" />
        <h3>${movie.Title}</h3>
      `;

      div.onclick = () => {
        window.location.href = `/movie/${movie.imdbID}`;
      };

      const favBtn = document.createElement("div");
      favBtn.classList.add("fav");
      favBtn.setAttribute("aria-label", `Agregar o quitar ${movie.Title} de favoritos`);
      favBtn.innerHTML = getFavorites().some(f => f.imdbID === movie.imdbID) ? "❤" : "♡";

      favBtn.onclick = (e) => {
        e.stopPropagation();
        let list = getFavorites();
        const exists = list.some(f => f.imdbID === movie.imdbID);

        if (exists) {
          list = list.filter(f => f.imdbID !== movie.imdbID);
          favBtn.innerHTML = "♡";
        } else {
          list.push(movie);
          favBtn.innerHTML = "❤";
          runAnimation(favBtn, "active");
        }

        localStorage.setItem("favs", JSON.stringify(list));
        notifyFavoritesChanged();
      };

      div.appendChild(favBtn);
      container.appendChild(div);
    });
  }

  async function fetchMovies(query) {
    const trimmedQuery = query.trim();
    const requestId = ++currentRequest;
    localStorage.setItem(SEARCH_QUERY_KEY, trimmedQuery);

    if (trimmedQuery.length === 0) {
      localStorage.removeItem(SEARCH_RESULTS_KEY);
      renderMessage("Escribí al menos 3 letras para buscar.");
      return;
    }

    if (trimmedQuery.length < 3) {
      renderMessage("Ingresá 3 o más letras para ver resultados.");
      return;
    }

    renderSkeletons();
    runAnimation(searchBtn, "grow-once");

    try {
      const res = await fetch(
        `https://www.omdbapi.com/?apikey=2a3fe01f&s=${encodeURIComponent(trimmedQuery)}`
      );
      const data = await res.json();

      if (requestId !== currentRequest) return;

      if (data.Response === "False") {
        localStorage.removeItem(SEARCH_RESULTS_KEY);
        renderMessage("No se encontraron resultados.");
        return;
      }

      saveSearchState(trimmedQuery, data.Search);
      renderMovies(data.Search);
      runAnimation(input, "grow-once");
    } catch {
      if (requestId !== currentRequest) return;
      renderMessage("Error al buscar. Intentá nuevamente.");
    }
  }

  function restoreLastSearch() {
    const savedQuery = localStorage.getItem(SEARCH_QUERY_KEY) || "";
    const rawResults = localStorage.getItem(SEARCH_RESULTS_KEY);

    input.value = savedQuery;
    if (!rawResults) {
      renderMessage("Escribí al menos 3 letras para buscar.");
      return;
    }

    try {
      const savedMovies = JSON.parse(rawResults);
      if (Array.isArray(savedMovies) && savedMovies.length > 0) {
        renderMovies(savedMovies);
        return;
      }
    } catch {
      localStorage.removeItem(SEARCH_RESULTS_KEY);
    }

    renderMessage("Escribí al menos 3 letras para buscar.");
  }

  input.addEventListener("input", () => {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => fetchMovies(input.value), 280);
  });

  searchBtn.addEventListener("click", () => fetchMovies(input.value));
  input.addEventListener("keydown", (event) => {
    if (event.key === "Enter") fetchMovies(input.value);
  });

  restoreLastSearch();
</script>