<input type="text" id="searchInput" placeholder="Buscar película..." />

<script>
  const input = document.getElementById("searchInput");
  const container = document.getElementById("movies");

  let currentPage = 1;
  let currentQuery = "";

  async function fetchMovies() {
    if (currentQuery.length < 3) return;

    container.innerHTML = "<p class='loader'>Cargando...</p>";

    const res = await fetch(`https://www.omdbapi.com/?apikey=2a3fe01f&s=${currentQuery}&page=${currentPage}`);
    const data = await res.json();

    container.innerHTML = "";

    if (data.Response === "False") {
      container.innerHTML = "<p>No hay resultados</p>";
      return;
    }

    data.Search.forEach(movie => {
      const div = document.createElement("div");
      div.classList.add("card");

      div.innerHTML = `
        <img src="${movie.Poster}" />
      `;

      // IR A DETALLE
      div.onclick = () => {
        window.location.href = `/movie/${movie.imdbID}`;
      };

      // FAVORITO
      const favBtn = document.createElement("div");
      favBtn.classList.add("fav");

      let favs = JSON.parse(localStorage.getItem("favs")) || [];
      const isFav = favs.some(f => f.imdbID === movie.imdbID);

      favBtn.innerText = isFav ? "💖" : "❤️";

      favBtn.onclick = (e) => {
        e.stopPropagation();

        let favs = JSON.parse(localStorage.getItem("favs")) || [];

        const exists = favs.find(f => f.imdbID === movie.imdbID);

        if (exists) {
          favs = favs.filter(f => f.imdbID !== movie.imdbID);
          favBtn.innerText = "❤️";
        } else {
          favs.push(movie);
          favBtn.innerText = "💖";
        }

        localStorage.setItem("favs", JSON.stringify(favs));
      };

      div.appendChild(favBtn);
      container.appendChild(div);
    });
  }

  input.addEventListener("input", () => {
    currentQuery = input.value;
    currentPage = 1;
    fetchMovies();
  });
</script>