---
import "../styles/global.css";
import SearchBar from "../components/SearchBar.astro";
---

<html>
  <body>
    <div class="container">

      <div class="header">
        <h1>&#127916; Movie Catalog</h1>

        <div>
          <span id="favCount" class="counter"></span>
          <button id="themeBtn">&#9790;</button>
          <button onclick="showFavs()">&#10084;</button>
        </div>
      </div>

      <SearchBar />

      <div id="movies" class="grid"></div>

    </div>

    <script>
      // 🔥 MODO GUARDADO
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme === "light") {
        document.body.classList.add("light");
      }

      const btn = document.getElementById("themeBtn");

      btn.onclick = () => {
        document.body.classList.toggle("light");

        const isLight = document.body.classList.contains("light");
        localStorage.setItem("theme", isLight ? "light" : "dark");
      };

      // 🔥 CONTADOR FAVORITOS
      function updateFavCount() {
        const favs = JSON.parse(localStorage.getItem("favs")) || [];
        document.getElementById("favCount").innerText = favs.length + " favs";
      }

      updateFavCount();

      // 🔥 MOSTRAR FAVORITOS (CON BORRAR)
      window.showFavs = () => {
        const container = document.getElementById("movies");
        let favs = JSON.parse(localStorage.getItem("favs")) || [];

        container.innerHTML = "";

        if (favs.length === 0) {
          container.innerHTML = "<p>No hay favoritos</p>";
          return;
        }

        favs.forEach(movie => {
          const div = document.createElement("div");
          div.classList.add("card");

          div.innerHTML = `
            <img src="${movie.Poster}" />
            <h3>${movie.Title}</h3>
          `;

          // IR A DETALLE
          div.onclick = () => {
            window.location.href = `/movie/${movie.imdbID}`;
          };

          // BOTÓN QUITAR
          const removeBtn = document.createElement("div");
          removeBtn.classList.add("fav");
          removeBtn.innerHTML = "&#10006;";

          removeBtn.onclick = (e) => {
            e.stopPropagation();

            favs = favs.filter(f => f.imdbID !== movie.imdbID);
            localStorage.setItem("favs", JSON.stringify(favs));

            showFavs();
            updateFavCount();
          };

          div.appendChild(removeBtn);
          container.appendChild(div);
        });
      };
    </script>
  </body>
</html>